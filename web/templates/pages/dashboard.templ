							<button class="px-3 py-1.5 text-xs font-semibold text-slate-400 bg-slate-50 border border-slate-200 rounded-lg cursor-not-allowed" disabled>Logs</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	}
